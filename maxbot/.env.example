# Скопируйте этот файл в .env и заполните значения

# MAX Bot API
# Токен получите у @MasterBot в MAX (создайте бота через команду /create)
MAX_BOT_TOKEN=YOUR_MAX_BOT_TOKEN_HERE
MAX_API_BASE=https://platform-api.max.ru

# Публичный URL вашего сервера для webhook (HTTPS обязательно).
# На Railway это будет что-то вроде https://maxbot-production-XXXX.up.railway.app
PUBLIC_BASE_URL=https://your-domain.example.com

# Случайный секрет для подписи webhook от MAX (любая длинная строка)
WEBHOOK_SECRET=change-me-to-random-32-bytes

# Случайный секрет для HMAC-подписи QR-токенов (любая длинная строка, отличная от WEBHOOK_SECRET)
QR_SECRET=another-random-secret-for-qr-codes

# Случайный секрет для подписи cookies Flask-сессии
FLASK_SECRET_KEY=yet-another-random-string-for-flask

# База данных PostgreSQL
# Локально: postgresql://user:pass@localhost:5432/maxbot
# На Railway переменная подставится автоматически
DATABASE_URL=postgresql://maxbot:maxbot@localhost:5432/maxbot

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Порт, на котором поднимается Flask (Railway переопределит через переменную PORT)
PORT=8080
